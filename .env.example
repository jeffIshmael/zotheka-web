# Privy — https://dashboard.privy.io
# 1. Settings → Clients → Add app client → choose WEB (not Mobile)
# 2. Add your deployment URL(s) to Allowed origins (localhost:3000 + Vercel URL)
# 3. Settings → Login methods → enable Email and Google
# 4. Use the same App ID as mobile; use the Web client ID below
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Flask backend URL (proxied at /backend via next.config rewrites — avoids browser CORS)
NEXT_PUBLIC_API_URL=https://blank-blank-pay.vercel.app

# Demo bypass: skip on-chain USDC for withdrawals (default: on)
NEXT_PUBLIC_DEMO_BYPASS_ONCHAIN=true
